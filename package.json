{
  "name": "@production-verify/core",
  "version": "0.1.0",
  "description": "Production verification framework — smoke tests + architecture proofs",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./nestjs": {
      "import": "./dist/nestjs/index.mjs",
      "require": "./dist/nestjs/index.cjs",
      "types": "./dist/nestjs/index.d.ts"
    },
    "./infrastructure": {
      "import": "./dist/infrastructure/index.mjs",
      "require": "./dist/infrastructure/index.cjs",
      "types": "./dist/infrastructure/index.d.ts"
    }
  },
  "bin": {
    "production-verify": "./dist/cli.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "ts-morph": ">=23.0.0"
  },
  "peerDependenciesMeta": {
    "ts-morph": {
      "optional": true
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "unbuild",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.1"
  }
}
